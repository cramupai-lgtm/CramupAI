rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Security validation primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // 3. Entity verification helper
    function isValidUser(data) {
      return data.get('uid', '') is string && data.get('uid', '').size() <= 128
          && data.get('email', '') is string && data.get('email', '').size() <= 256
          && (data.get('account_tier', 'Free') == 'Free' || data.get('account_tier', 'Free') == 'Premium')
          && data.get('selected_subject', 'Biology') is string && data.get('selected_subject', 'Biology').size() <= 128
          && (data.get('monthly_uploads_used_counter', 0) is int || data.get('monthly_uploads_used_counter', null) == null);
    }

    // 4. Access rules per collection
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().get('uid', '') == existing().get('uid', '');
    }

    // Helper to verify if the auth user owns the material
    function isMaterialOwner(materialId) {
      return isSignedIn() && get(/databases/$(database)/documents/materials/$(materialId)).data.user_id == request.auth.uid;
    }

    match /materials/{materialId} {
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow get: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && existing().user_id == request.auth.uid && incoming().user_id == existing().user_id;
      allow delete: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    match /quiz_records/{quizId} {
      allow list: if isSignedIn() && isMaterialOwner(resource.data.material_id);
      allow get: if isSignedIn() && isMaterialOwner(resource.data.material_id);
      allow create: if isSignedIn() && isMaterialOwner(incoming().material_id);
      allow update: if isSignedIn() && isMaterialOwner(existing().material_id) && isMaterialOwner(incoming().material_id);
      allow delete: if isSignedIn() && isMaterialOwner(existing().material_id);
    }

    match /flashcards/{flashcardId} {
      allow list: if isSignedIn() && isMaterialOwner(resource.data.material_id);
      allow get: if isSignedIn() && isMaterialOwner(resource.data.material_id);
      allow create: if isSignedIn() && isMaterialOwner(incoming().material_id);
      allow update: if isSignedIn() && isMaterialOwner(existing().material_id) && isMaterialOwner(incoming().material_id);
      allow delete: if isSignedIn() && isMaterialOwner(existing().material_id);
    }

    match /chat_log/{chatId} {
      allow list: if isSignedIn() && isMaterialOwner(resource.data.material_id);
      allow get: if isSignedIn() && isMaterialOwner(resource.data.material_id);
      allow create: if isSignedIn() && isMaterialOwner(incoming().material_id);
    }
  }
}
